<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>極客終端機 - AI 解答之書</title>
  <style>
    /* 全域終端機風格設定 */
    body {
      background-color: #0a0a0a;
      color: #00ff33;
      font-family: 'Courier New', Courier, monospace;
      padding: 20px;
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      box-sizing: border-box;
    }

    /* 終端機主視窗外殼 */
    .terminal-window {
      width: 100%;
      max-width: 800px;
      background-color: #111;
      /*border: 2px solid #00ff33;*/
      box-shadow: 0 0 20px rgba(0, 255, 51, 0.2);
      border-radius: 5px;
      overflow: hidden;
    }

    /* 視窗頂部控制列 */
    .terminal-header {
      background-color: #222;
      padding: 10px;
      display: flex;
      align-items: center;
      border-bottom: 1px solid #333;
    }

    .buttons {
      display: flex;
      gap: 8px;
    }

    .button-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }

    .dot-red {
      background-color: #ff5f56;
    }

    .dot-yellow {
      background-color: #ffbd2e;
    }

    .dot-green {
      background-color: #27c93f;
    }

    .window-title {
      margin-left: 20px;
      font-size: 14px;
      color: #888;
    }

    /* 終端機內容輸出區 */
    .terminal-body {
      padding: 20px;
      height: 400px;
      overflow-y: auto;
      font-size: 16px;
      line-height: 1.5;
    }

    /* 功能按鈕區（取代原本死板的純打字） */
    .action-panel {
      margin-top: 20px;
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .geek-btn {
      background-color: transparent;
      color: #00ff33;
      border: 1px solid #00ff33;
      padding: 10px 20px;
      font-family: 'Courier New', Courier, monospace;
      font-size: 15px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
    }

    .geek-btn:hover {
      background-color: #00ff33;
      color: #0a0a0a;
      box-shadow: 0 0 15px rgba(0, 255, 51, 0.6);
    }

    /* 🔥 動態彈出對話格 (Modal) 樣式 */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.8);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .modal-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }

    .modal-box {
      background-color: #111;
      border: 2px solid #00ff33;
      padding: 30px;
      border-radius: 5px;
      width: 90%;
      max-width: 500px;
      box-shadow: 0 0 25px rgba(0, 255, 51, 0.4);
      text-align: left;
    }

    .modal-box h3 {
      margin-top: 0;
      color: #00ff33;
    }

    .modal-input {
      width: 100%;
      background-color: #000;
      border: 1px solid #00ff33;
      color: #00ff33;
      padding: 10px;
      font-family: 'Courier New', Courier, monospace;
      font-size: 16px;
      box-sizing: border-box;
      margin-bottom: 20px;
      outline: none;
    }

    .modal-buttons {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    /* 游標閃爍效果 */
    .cursor {
      display: inline-block;
      width: 10px;
      height: 18px;
      background-color: #00ff33;
      animation: blink 0.8s infinite;
      vertical-align: middle;
    }

    @keyframes blink {
      50% {
        opacity: 0;
      }
    }
  </style>
</head>

<body>

  <div class="terminal-window">
    <div class="terminal-header">
      <div class="buttons">
        <div class="button-dot dot-red"></div>
        <div class="button-dot dot-yellow"></div>
        <div class="button-dot dot-green"></div>
      </div>
      <div class="window-title">universe_terminal.sh</div>
    </div>
    <div class="terminal-body" id="output">
      <div>[System] 系統初始化成功...</div>
      <div>[System] 正在連線至宇宙核心解碼器...</div>
      <div>[System] 請點擊下方指令開始占卜。</div>
      <div>[System] 貼心提醒，問題請以封閉式問題的格式提問<span class="cursor"></span></div>
    </div>
  </div>

  <div class="action-panel">
    <button class="geek-btn" onclick="triggerRandomAnswer()">[ 隨機抽取解答 ]</button>
    <button class="geek-btn" onclick="openQuestionModal()">[ 輸入問題占卜 ]</button>
    <button class="geek-btn" onclick="fetchHistory()">[ 查看歷史紀錄 ]</button>
    <button class="geek-btn" onclick="clearHistoryFromServer()" style="color: #ff5f56; border-color: #ff5f56;">[ 清除歷史紀錄
      ]</button>
  </div>

  <div class="modal-overlay" id="questionModal">
    <div class="modal-box">
      <h3>> 請輸入你想向宇宙詢問的問題：</h3>
      <input type="text" id="userQuestionInput" class="modal-input" placeholder="例如：我這學期期末考會過嗎？" autocomplete="off">
      <div class="modal-buttons">
        <button class="geek-btn" onclick="closeQuestionModal()">取消</button>
        <button class="geek-btn" onclick="submitQuestion()">送出冥想</button>
      </div>
    </div>
  </div>

  <script>
    const outputDiv = document.getElementById('output');
    const modal = document.getElementById('questionModal');
    const questionInput = document.getElementById('userQuestionInput');

    // 將訊息輸出到終端機畫面的輔助函式
    function logToTerminal(message, type = 'info') {
      const prefix = type === 'error' ? '[Error] ' : type === 'success' ? '[Success] ' : '> ';
      const div = document.createElement('div');
      div.textContent = prefix + message;
      outputDiv.appendChild(div);
      outputDiv.scrollTop = outputDiv.scrollHeight; // 自動捲動到最底部
    }

    // 開啟彈出填寫格
    function openQuestionModal() {
      modal.classList.add('active');
      questionInput.value = ''; // 清空欄位
      setTimeout(() => questionInput.focus(), 100); // 自動聚焦
    }

    // 關閉彈出填寫格
    function closeQuestionModal() {
      modal.classList.remove('active');
    }

    // 監聽彈出框的 Enter 鍵送出
    questionInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        submitQuestion();
      }
    });

    // 處理 [輸入問題占卜] 送出
    async function submitQuestion() {
      const question = questionInput.value.trim();
      if (!question) {
        alert('請先輸入問題！');
        return;
      }

      closeQuestionModal(); // 關閉對話框
      logToTerminal(`使用者提問: ${question}`);

      // 駭客炫技感：分析中動畫
      logToTerminal('正在分析量子力學機率矩陣...', 'info');
      logToTerminal('正在與天界大數據進行特徵匹配...', 'info');

      try {
        // 呼叫後端 API（帶上問題參數）
        const response = await fetch(`/api/get_answer?question=${encodeURIComponent(question)}`);
        const data = await response.json();

        if (data.status === 'success') {
          // 延遲 1 秒顯示解答，加強儀式感
          setTimeout(() => {
            logToTerminal(`宇宙給予的啟示: ${data.answer}`, 'success');
          }, 1000);
        } else {
          logToTerminal(`核心解碼失敗: ${data.message}`, 'error');
        }
      } catch (error) {
        logToTerminal('無法連線到預言伺服器。', 'error');
      }
    }

    // 處理 [隨機抽取解答] 按鈕
    async function triggerRandomAnswer() {
      logToTerminal('觸發隨機解答封包抽取...');
      try {
        // 不帶 question 參數，後端就會執行隨機抽取
        const response = await fetch('/api/get_answer');
        const data = await response.json();
        if (data.status === 'success') {
          logToTerminal(`隨機啟示: ${data.answer}`, 'success');
        } else {
          logToTerminal('抽取失敗。', 'error');
        }
      } catch (error) {
        logToTerminal('連線異常。', 'error');
      }
    }

    // 處理 [查看歷史紀錄] 按鈕
    async function fetchHistory() {
      logToTerminal('正在讀取本機 SQLite 歷史占卜日誌...');
      try {
        const response = await fetch('/api/get_history');
        const data = await response.json();

        if (data.status === 'success' && data.history.length > 0) {
          logToTerminal('--- 歷史紀錄查詢結果 (最新10筆) ---');
          data.history.forEach((item, index) => {
            logToTerminal(`[${item.time}] 問: ${item.question || '無'} -> 答: ${item.answer}`);
          });
          logToTerminal('----------------------------------');
        } else {
          logToTerminal('查無任何占卜紀錄。', 'info');
        }
      } catch (error) {
        logToTerminal('歷史紀錄讀取失敗。', 'error');
      }
    }

    // 🔥 全新新增：呼叫後端 API 清除所有歷史紀錄
      async function clearHistoryFromServer() {
        // 跳出瀏覽器內建確認視窗，防止手殘誤點
        if (!confirm("確定要永遠抹除宇宙中所有的占卜歷史紀錄嗎？此操作無法復原。")) {
          return;
        }

        logToTerminal('正在對 SQLite 資料庫發送重置訊號...', 'info');

        try {
          // 呼叫我們剛剛在後端寫好的 API
          const response = await fetch('/api/clear_history', { method: 'POST' });
          const data = await response.json();

          if (data.status === 'success') {
            logToTerminal(data.message, 'success');
            logToTerminal('歷史紀錄快取已重置。', 'info');
          } else {
            logToTerminal(`抹除紀錄失敗：${data.message}`, 'error');
          }
        } catch (error) {
          logToTerminal('無法連線到預言伺服器進行清除動作。', 'error');
        }
      }
  </script>
